/* ===== Design tokens ===== */
page {
  --primary: #FF6B6B;
  --accent: #FF8C42;
  --gradient: linear-gradient(135deg, #FF6B6B 0%, #FF8C42 100%);
  --bg: #FFFAF5;
  --card: #FFFFFF;
  --border: #F1E6DD;
  --text: #1F1F1F;
  --muted: #8B8580;
  --success: #2BB673;

  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
}

/* ===== Layout ===== */
.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.gradient-header {
  background: var(--gradient);
  color: #fff;
  padding: 80rpx 40rpx 80rpx;
  border-radius: 0 0 40rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.gradient-header::after {
  content: "";
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  right: -120rpx;
  top: -120rpx;
}

.gh-logo {
  font-size: 84rpx;
  line-height: 1;
}

.gh-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-top: 14rpx;
  letter-spacing: 1rpx;
}

.gh-sub {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 6rpx;
}

.section {
  padding: 40rpx 32rpx 0;
}

/* ===== Card ===== */
.card {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.label {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.muted {
  color: var(--muted);
  font-size: 24rpx;
}

.error {
  color: #d4351c;
  font-size: 26rpx;
  margin: 12rpx 32rpx 0;
}

/* ===== Buttons ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  border-radius: 20rpx;
  background: var(--gradient);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1px;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.32);
}

.btn::after {
  border: none;
}

.btn[disabled] {
  opacity: 0.5;
}

.btn.outline {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  box-shadow: none;
}

.btn.ghost {
  background: #fff7f1;
  color: var(--primary);
  box-shadow: none;
}

/* ===== Pill segment switch ===== */
.segment {
  display: flex;
  background: #FFEFE3;
  border-radius: 999rpx;
  padding: 6rpx;
  gap: 6rpx;
}

.segment.large {
  padding: 8rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--muted);
  transition: all 0.18s ease;
}

.segment.large .segment-item {
  padding: 22rpx 0;
  font-size: 28rpx;
}

.segment-item.active {
  background: var(--gradient);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(255, 107, 107, 0.32);
}

/* ===== Picker box ===== */
.field {
  background: #FFFAF5;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field .arrow {
  color: var(--muted);
  font-size: 22rpx;
}

.col-2 {
  display: flex;
  gap: 16rpx;
}

.col-2 > view {
  flex: 1;
  min-width: 0;
}

/* ===== Tag ===== */
.tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #FFEFE3;
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 600;
}

.tag.outline {
  background: transparent;
  border: 2rpx solid var(--accent);
}

/* ===== Input ===== */
.text-input {
  width: 100%;
  min-height: 200rpx;
  padding: 22rpx;
  background: #FFFAF5;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}
