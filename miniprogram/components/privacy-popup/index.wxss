.pp-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 56rpx;
}

.pp-card {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 32rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.18);
}

.pp-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2b2b2b;
  text-align: center;
  margin-bottom: 24rpx;
}

.pp-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
  margin-bottom: 12rpx;
}

.pp-link {
  font-size: 28rpx;
  color: #ff6b6b;
  margin-bottom: 32rpx;
}

.pp-actions {
  display: flex;
  gap: 24rpx;
}

.pp-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
  border: none;
}

.pp-btn::after {
  border: none;
}

.pp-btn-no {
  background: #f4f4f4;
  color: #666;
}

.pp-btn-yes {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8c42 100%);
  color: #fff;
  font-weight: 600;
}
