.gh-about {
  position: absolute;
  top: 28rpx;
  right: 32rpx;
  z-index: 2;
  padding: 10rpx 22rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(8rpx);
}

.gh-about-hover {
  background: rgba(255, 255, 255, 0.4);
}

.cards {
  padding: 40rpx 32rpx 0;
  margin-top: -40rpx;
}

.entry {
  background: var(--card);
  border: 2rpx solid #FFE7DA;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 140, 90, 0.10);
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
}

.entry-hover {
  transform: scale(0.98);
  background: #fff7f1;
}

.entry::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--gradient);
  border-radius: 8rpx 0 0 8rpx;
}

.entry-icon {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(160deg, #FFE8D5 0%, #FFC9A8 100%);
  border: 5rpx solid #FFFFFF;
  box-shadow:
    0 8rpx 18rpx rgba(255, 140, 90, 0.22),
    0 0 0 3rpx #FFD9BD;
  overflow: hidden;
}

.entry-icon-img {
  width: 94%;
  height: 94%;
  display: block;
  background: transparent;
}

.entry.cat .entry-icon {
  background: linear-gradient(160deg, #FFE0EC 0%, #FFB8D2 100%);
  box-shadow:
    0 8rpx 18rpx rgba(255, 130, 170, 0.24),
    0 0 0 3rpx #FFC9DC;
}

.entry.dog .entry-icon {
  background: linear-gradient(160deg, #FFEAC9 0%, #FFC68A 100%);
  box-shadow:
    0 8rpx 18rpx rgba(255, 165, 80, 0.24),
    0 0 0 3rpx #FFD7A8;
}

.entry-body {
  flex: 1;
  min-width: 0;
}

.entry-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.entry-sub {
  font-size: 24rpx;
  color: var(--muted);
}

.entry-arrow {
  font-size: 56rpx;
  color: #FFB58A;
  font-weight: 300;
  line-height: 1;
}

