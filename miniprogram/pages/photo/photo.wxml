<view class="page">
  <privacy-popup />
  <view class="gradient-header">
    <view class="gh-logo-wrap">
      <image class="gh-logo-img" src="/images/pet.png" mode="aspectFit" />
    </view>
    <view class="gh-title">趣味照片</view>
    <view class="gh-sub">上传一张毛孩子的照片 · 生成趣味文案海报</view>
  </view>

  <view class="section">
    <!-- Upload card -->
    <view class="card upload-card">
      <view class="card-title">📤 上传照片</view>

      <block wx:if="{{!previewPath && !fileName}}">
        <view class="cartoon-avatar wide">
          <image class="cartoon-avatar-img" src="/images/pet.png" mode="aspectFit" />
        </view>
        <view class="upload-box" bindtap="chooseFromAlbum">
          <view class="upload-icon">＋</view>
          <view class="upload-tip">点击从相册或拍照</view>
          <view class="upload-sub">或下方按钮从聊天文件中选择</view>
        </view>
      </block>

      <block wx:else>
        <view class="preview-wrap">
          <image
            wx:if="{{previewPath}}"
            class="preview-img"
            src="{{previewPath}}"
            mode="aspectFill"
            bindtap="previewLocal"
          />
          <view wx:else class="preview-placeholder">
            <view class="ph-icon">🖼️</view>
            <view>HEIC/HEIF 文件</view>
            <view class="muted">小程序无法本地预览，将由后端解析</view>
          </view>
          <view class="preview-name">{{fileName}}</view>
          <view class="preview-actions">
            <view class="chip" bindtap="chooseFromAlbum">📷 重选</view>
            <view class="chip" bindtap="chooseFromFile">📂 选文件</view>
            <view class="chip danger" bindtap="clearFile">✕ 删除</view>
          </view>
        </view>
      </block>

      <view wx:if="{{!previewPath && !fileName}}" class="dual-btn">
        <view class="btn ghost half" bindtap="chooseFromAlbum">📷 相册/拍照</view>
        <view class="btn ghost half" bindtap="chooseFromFile">📂 聊天文件</view>
      </view>

      <view class="format-tags">
        <view class="format-label">支持格式</view>
        <view class="format-list">
          <view class="format-tag">JPG</view>
          <view class="format-tag">PNG</view>
          <view class="format-tag">WEBP</view>
          <view class="format-tag">HEIC</view>
          <view class="format-tag">BMP</view>
          <view class="format-tag">GIF</view>
        </view>
      </view>

      <!-- 海报模式切换：原图 / AI 重绘 -->
      <view class="mode-block">
        <view class="mode-segment">
          <view
            class="mode-pill {{mode === 'origin' ? 'active' : ''}}"
            data-mode="origin"
            bindtap="switchMode"
          >
            <view class="mode-pill-title">📷 原图模板</view>
            <view class="mode-pill-sub">免费 · 不限次</view>
          </view>
          <view
            class="mode-pill {{mode === 'redraw' ? 'active' : ''}}"
            data-mode="redraw"
            bindtap="switchMode"
          >
            <view class="mode-pill-title">🎨 AI 重绘</view>
            <view class="mode-pill-sub">
              <text wx:if="{{redrawLimit > 0}}">
                今日剩余 {{redrawRemaining}} 次<text wx:if="{{redrawBonus > 0}}">（含分享 +{{redrawBonus}}）</text>
              </text>
              <text wx:else>风格化重绘</text>
            </view>
          </view>
        </view>

        <!-- 风格选择（仅 AI 重绘模式显示） -->
        <view wx:if="{{mode === 'redraw'}}" class="style-list">
          <view
            wx:for="{{artStyleOptions}}"
            wx:key="key"
            class="style-chip {{artStyle === item.key ? 'active' : ''}}"
            data-key="{{item.key}}"
            bindtap="switchStyle"
          >
            <view class="style-chip-emoji">{{item.emoji}}</view>
            <view class="style-chip-label">{{item.label}}</view>
          </view>
        </view>

        <view wx:if="{{mode === 'redraw' && redrawRemaining === 0 && redrawLimit < redrawCap}}" class="quota-empty">
          <view class="quota-empty-emoji">😢</view>
          <view class="quota-empty-title">今日基础额度用完啦</view>
          <view class="quota-empty-sub">分享一次 +2 次 · 每天最多 {{redrawCap}} 次</view>
        </view>
        <view wx:if="{{mode === 'redraw' && redrawRemaining === 0 && redrawLimit >= redrawCap}}" class="quota-warn">
          ⚠️ 今日已达上限({{redrawCap}} 次),明天再来吧～
        </view>
      </view>

      <view wx:if="{{errorMsg}}" class="error">{{errorMsg}}</view>

      <button
        wx:if="{{mode !== 'redraw' || redrawRemaining > 0 || redrawLimit >= redrawCap}}"
        class="btn big-btn"
        bindtap="startTranslate"
        loading="{{loading}}"
        disabled="{{loading || !fileName || (mode === 'redraw' && redrawRemaining === 0)}}"
      >
        <text wx:if="{{mode === 'redraw'}}">🎨 AI 重绘 · 生成海报(消耗 1 次)</text>
        <text wx:else>✨ 生成趣味文案海报</text>
      </button>

      <button
        wx:if="{{mode === 'redraw' && redrawRemaining === 0 && redrawLimit < redrawCap}}"
        class="btn big-btn share-bonus-btn"
        open-type="share"
        bindtap="prepareShareBonus"
      >
        📣 分享好友 · 立得 +2 次重绘
      </button>

      <view
        wx:if="{{mode === 'redraw' && redrawRemaining > 0 && redrawLimit < redrawCap}}"
        class="share-link-tip"
      >
        想多画几张?
        <text class="share-link" bindtap="openShareDialog">分享好友 +2 次</text>
      </view>
    </view>

    <!-- Result card -->
    <block wx:if="{{quote || vibeLabel || persona}}">
      <view class="card result-card">
        <view class="card-title">💬 趣味文案</view>
        <view class="quote-cn">{{quote}}</view>
        <view wx:if="{{vibe}}" class="quote-en">"{{vibe}}"</view>
        <view class="result-tags">
          <view wx:if="{{vibeLabel}}" class="tag">🎨 {{vibeLabel}}</view>
          <view wx:if="{{persona}}" class="tag outline">👤 {{persona}}</view>
          <view wx:for="{{pets}}" wx:key="*this" class="tag outline">🐾 {{item}}</view>
        </view>
        <view class="disclaimer-block">
          <view class="disclaimer">✨ AI 生成内容 · 仅供娱乐，请勿当真</view>
        </view>
      </view>
    </block>

    <!-- Palette card -->
    <view wx:if="{{palette.length}}" class="card">
      <view class="card-title">🎨 色卡</view>
      <view class="palette">
        <view
          wx:for="{{palette}}"
          wx:key="*this"
          class="swatch"
          style="background:{{item}}"
        >
          <view class="swatch-hex">{{item}}</view>
        </view>
      </view>
    </view>

    <!-- Poster -->
    <view wx:if="{{posterImageSrc}}" class="card poster-card">
      <view class="card-title">🖼️ 海报预览</view>
      <view class="poster-frame" bindtap="previewPoster">
        <image
          class="poster-img"
          src="{{posterImageSrc}}"
          mode="widthFix"
          show-menu-by-longpress="{{true}}"
        />
      </view>
      <view class="dual-btn">
        <button class="btn big-btn half" bindtap="savePoster">💾 保存海报</button>
        <button class="btn big-btn half outline" open-type="share">↗ 分享好友</button>
      </view>
      <view class="poster-tip-wrap">
        <view class="poster-tip-pill">👆 点击全屏 · ✋ 长按图片可保存/识别二维码</view>
      </view>
    </view>

    <!-- 历史按钮 -->
    <view class="history-fab" hover-class="hf-hover" bindtap="openHistory">
      <view class="hf-icon">🕘</view>
      <view class="hf-text">最近</view>
    </view>
  </view>

  <!-- 历史抽屉 -->
  <view wx:if="{{historyOpen}}" class="hist-mask" catchtap="closeHistory">
    <view class="hist-sheet" catchtap="noop">
      <view class="hist-head">
        <view class="hist-title">最近翻译</view>
        <view class="hist-clear" bindtap="clearHistory">清空</view>
      </view>
      <view wx:if="{{!historyList.length}}" class="hist-empty">
        还没有记录哦，先翻译一张照片吧～
      </view>
      <scroll-view scroll-y class="hist-list" wx:else>
        <view
          wx:for="{{historyList}}"
          wx:key="time"
          class="hist-item"
          data-idx="{{index}}"
          bindtap="reopenHistoryItem"
        >
          <image
            wx:if="{{item.previewPath}}"
            class="hist-thumb"
            src="{{item.previewPath}}"
            mode="aspectFill"
          />
          <view wx:else class="hist-thumb hist-thumb-fallback">🖼️</view>
          <view class="hist-body">
            <view class="hist-quote">{{item.quote || '（无文案）'}}</view>
            <view class="hist-meta">
              <text wx:if="{{item.vibeLabel}}" class="hist-tag">{{item.vibeLabel}}</text>
              <text class="hist-time">{{item._t}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
