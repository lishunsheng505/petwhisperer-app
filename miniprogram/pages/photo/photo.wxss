.upload-card {
  padding: 32rpx 32rpx 24rpx;
}

.upload-box {
  border: 4rpx dashed #FFB58A;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #FFF7F1 0%, #FFEFDF 100%);
  padding: 70rpx 32rpx;
  text-align: center;
  box-shadow: inset 0 4rpx 14rpx rgba(255, 200, 160, 0.25);
}

.upload-icon {
  font-size: 80rpx;
  color: var(--primary);
  font-weight: 200;
  line-height: 1;
}

.upload-tip {
  font-size: 30rpx;
  color: var(--primary);
  font-weight: 600;
  margin-top: 16rpx;
}

.upload-sub {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

.dual-btn {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.dual-btn .half {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}

.preview-wrap {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  background: #FFFAF5;
  border: 2rpx solid var(--border);
}

.preview-img {
  width: 100%;
  height: 460rpx;
  display: block;
}

.preview-placeholder {
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: var(--muted);
}

.ph-icon {
  font-size: 80rpx;
}

.preview-name {
  padding: 14rpx 20rpx;
  font-size: 24rpx;
  color: var(--muted);
  border-top: 2rpx solid var(--border);
  background: #fff;
  word-break: break-all;
}

.preview-actions {
  display: flex;
  gap: 12rpx;
  padding: 14rpx 20rpx;
  background: #fff;
  border-top: 2rpx solid var(--border);
  flex-wrap: wrap;
}

.chip {
  padding: 10rpx 22rpx;
  background: #FFEFE3;
  color: var(--primary);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.chip.danger {
  background: #FFE5E5;
  color: #d4351c;
}

.format-tags {
  margin-top: 24rpx;
  background: #FFFAF5;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.format-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 10rpx;
}

.format-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.format-tag {
  background: #fff;
  border: 2rpx solid var(--border);
  color: var(--text);
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.big-btn {
  margin-top: 32rpx;
}

.result-card {
  position: relative;
  overflow: hidden;
}

.result-card::before {
  content: "";
  position: absolute;
  top: 0; right: 0;
  width: 200rpx; height: 200rpx;
  background: radial-gradient(circle at top right, rgba(255, 140, 66, 0.12), transparent 70%);
}

.quote-cn {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.5;
  color: var(--text);
}

.quote-en {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--accent);
  font-style: italic;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.palette {
  display: flex;
  gap: 16rpx;
}

.swatch {
  flex: 1;
  height: 200rpx;
  border-radius: 18rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.swatch-hex {
  position: absolute;
  bottom: 12rpx;
  left: 0; right: 0;
  text-align: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 1rpx;
  background: rgba(0,0,0,0.28);
  padding: 6rpx 0;
  backdrop-filter: blur(2rpx);
}

.poster-frame {
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.16);
  margin-bottom: 24rpx;
}

.poster-img {
  width: 100%;
  display: block;
}

.poster-tip {
  text-align: center;
  margin-top: 14rpx;
}

.poster-tip-wrap {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.poster-tip-pill {
  font-size: 22rpx;
  color: #C95B00;
  background: #FFF1E0;
  border: 2rpx dashed #FFB58A;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  letter-spacing: 0.5rpx;
}

/* outline 半宽按钮 */
.dual-btn .half.outline {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  box-shadow: none;
}

/* ===== 历史浮动按钮 + 抽屉 ===== */
.history-fab {
  position: fixed;
  right: 28rpx;
  bottom: 140rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--gradient);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(255, 107, 107, 0.36);
  z-index: 50;
}

.hf-icon {
  font-size: 38rpx;
  line-height: 1;
}

.hf-text {
  font-size: 18rpx;
  margin-top: 2rpx;
  letter-spacing: 1rpx;
}

.hf-hover {
  transform: scale(0.94);
}

.hist-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.hist-sheet {
  width: 100%;
  max-height: 78vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx 40rpx;
  box-shadow: 0 -12rpx 32rpx rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
}

.hist-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 20rpx;
}

.hist-title {
  font-size: 32rpx;
  font-weight: 700;
}

.hist-clear {
  font-size: 24rpx;
  color: var(--muted);
  padding: 6rpx 16rpx;
  border: 2rpx solid var(--border);
  border-radius: 999rpx;
}

.hist-empty {
  text-align: center;
  color: var(--muted);
  padding: 80rpx 0;
  font-size: 26rpx;
}

.hist-list {
  flex: 1;
  overflow: hidden;
}

.hist-item {
  display: flex;
  gap: 20rpx;
  padding: 18rpx 8rpx;
  border-bottom: 2rpx dashed #FFE7DA;
}

.hist-item:last-child {
  border-bottom: none;
}

.hist-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #FFFAF5;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  overflow: hidden;
}

.hist-thumb-fallback {
  background: linear-gradient(160deg, #FFE8D5, #FFC9A8);
}

.hist-body {
  flex: 1;
  min-width: 0;
}

.hist-quote {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.hist-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.hist-tag {
  background: #FFEFE3;
  color: var(--accent);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}
